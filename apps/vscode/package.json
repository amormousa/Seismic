{
  "name": "seismic-stats",
  "displayName": "Seismic Stats",
  "description": "Your code speaks. We listen.",
  "version": "0.1.2",
  "publisher": "muhannad",
  "license": "GPL-3.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Majoramari/Seismic.git",
    "directory": "apps/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Education"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "seismic.setApiKey",
        "title": "Seismic: Set API Key"
      },
      {
        "command": "seismic.openDashboard",
        "title": "Seismic: Open Dashboard"
      },
      {
        "command": "seismic.enable",
        "title": "Seismic: Enable Tracking"
      },
      {
        "command": "seismic.disable",
        "title": "Seismic: Disable Tracking"
      }
    ],
    "configuration": {
      "title": "Seismic",
      "properties": {
        "seismic.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your Seismic API key from seismic.icu/settings"
        },
        "seismic.apiUrl": {
          "type": "string",
          "default": "https://correct-wolverine-majoramari-6049fd71.koyeb.app",
          "description": "Seismic API URL"
        },
        "seismic.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable Seismic time tracking"
        },
        "seismic.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show today's coding time in the status bar"
        }
      }
    }
  },
  "scripts": {
    "build": "bun build src/extension.ts --outdir dist --target node --external vscode",
    "test": "bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "^1.3.14",
    "@types/node": "latest",
    "@types/vscode": "^1.85.0",
    "typescript": "^5"
  }
}
